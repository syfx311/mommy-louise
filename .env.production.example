# Production Environment Variables
# Copy this to your Vercel dashboard or production .env file
# Replace all <values> with your actual keys

# ============================================
# SUPABASE (Database)
# Already configured, copy from your project
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# RESEND (Email Service)
# Sign up at https://resend.com
# Create API key from dashboard
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# ADMIN SETTINGS
# Change email to your admin email
# Use strong password (12+ chars with symbols)
# ============================================
NEXT_PUBLIC_ADMIN_PASSWORD=YourSecurePassword123!@#
ADMIN_EMAIL=admin@yourdomain.com

# ============================================
# APP CONFIGURATION
# Set to your production domain
# ============================================
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ============================================
# OPTIONAL: Legacy Email (can be removed)
# Only if you're keeping old email system
# ============================================
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# ============================================
# DEPLOYMENT NOTES
# ============================================
# For Vercel:
# 1. Go to Project Settings → Environment Variables
# 2. Add each variable with its value
# 3. Select "Production" for environment
# 4. Redeploy to apply changes
#
# For Email Domain Setup (Optional):
# 1. Add custom domain in Resend
# 2. Verify DNS records (SPF/DKIM)
# 3. Update lib/resend.ts sender address
# 4. Example: orders@yourdomain.com
#
# Security Notes:
# - Never commit .env files with real keys
# - Use Vercel's environment variables UI
# - Rotate API keys periodically
# - Use strong admin passwords
# - Keep RESEND_API_KEY secret
